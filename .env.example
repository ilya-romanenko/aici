# =============================================================================
# AICI — Environment Variables Template
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# CORE CONFIGURATION
# ---------------------------------------------------------------------------
AI_CRYPTO_CONFIG=config/pipeline.json
AICI_DEV=0
AICI_LOG_LEVEL=INFO
AICI_ALLOWED_ORIGINS=https://your-frontend-domain.com
AICI_PREFER_SRC_TEMPLATES=0

# ---------------------------------------------------------------------------
# API & SERVER
# ---------------------------------------------------------------------------
AICI_HOST=0.0.0.0
AICI_PORT=8000
AICI_UVICORN_WORKERS=2
AICI_UVICORN_RELOAD=0
AICI_RUNS_ROOT=/data/runs
AICI_DATA_ROOT=/data

# ---------------------------------------------------------------------------
# PIPELINE & SCHEDULER
# ---------------------------------------------------------------------------
AICI_ENABLE_PIPELINE=1
AICI_RUN_PIPELINE_ON_START=never
AICI_FAIL_ON_BOOTSTRAP_ERROR=0
AICI_PERFORMANCE_AUTO_ENABLED=1
AICI_PERFORMANCE_POLL_SECONDS=3600
AICI_DAILY_SNAPSHOT_ENABLED=1
AICI_DAILY_SNAPSHOT_HOUR_UTC=0
AICI_DAILY_SNAPSHOT_MINUTE_UTC=0
AICI_DAILY_SNAPSHOT_BASE_URI=/data/snapshots
AICI_DAILY_SNAPSHOT_BASE_URL=https://your-domain.com/snapshots
AICI_BILLING_REMINDERS_ENABLED=1
AICI_BILLING_REMINDER_SECONDS=3600
AICI_INDEX_AUTO_POLL_SECONDS=21600
AICI_INDEX_AUTO_PREFIX=auto-classic
AICI_INDEX_AUTO_PREFIX_CONSERVATIVE=auto-conservative
AICI_INDEX_AUTO_PREFIX_AGGRESSIVE=auto-aggressive
AICI_MONTHLY_JOB_LOCK_STALE_SECONDS=21600

# ---------------------------------------------------------------------------
# CTA FORMAT OPTIMIZATION
# ---------------------------------------------------------------------------
AICI_CTA_FORMAT_OPTIMIZATION_ENABLED=1
AICI_CTA_FORMAT_OPTIMIZATION_POLL_SECONDS=3600
AICI_CTA_FORMAT_OPTIMIZATION_WINDOW_DAYS=30
AICI_CTA_FORMAT_OPTIMIZATION_TOP_N=5
AICI_CTA_RETENTION_CHECK_SECONDS=3600
AICI_CTA_FACT_RETENTION_DAYS=90
AICI_CTA_RETENTION_BATCH_SIZE=500
AICI_CTA_ARCHIVE_FILE_RETENTION_DAYS=30
AICI_CUSTOM_SNAPSHOT_LIMIT=100
AICI_CUSTOM_SNAPSHOT_TTL_DAYS=7

# ---------------------------------------------------------------------------
# RATE LIMITING
# ---------------------------------------------------------------------------
AICI_RATE_LIMIT=120
AICI_RATE_LIMIT_WINDOW=60
AICI_SIGNUP_RATE_LIMIT=5
AICI_SIGNUP_RATE_WINDOW=60
AICI_RESEND_RATE_LIMIT=5
AICI_RESEND_RATE_WINDOW=60

# ---------------------------------------------------------------------------
# AUTHENTICATION & JWT
# ---------------------------------------------------------------------------
AICI_AUTH_DATABASE_URL=postgresql://user:password@localhost:5432/aici_auth
AICI_AUTH_JWT_SECRET=change_me_use_a_long_random_string
AICI_AUTH_JWT_ALG=HS256
AICI_AUTH_ACCESS_TTL=3600
AICI_AUTH_REFRESH_TTL=2592000
AICI_AUTH_EMAIL_TOKEN_TTL=259200
AICI_AUTH_RESET_TOKEN_TTL=3600
AICI_AUTH_SESSION_COOKIE=aici_session
AICI_AUTH_SESSION_DOMAIN=your-domain.com
AICI_AUTH_SESSION_SECURE=1
AICI_AUTH_DEBUG_TOKENS=0
AICI_AUTH_ECHO_SQL=0
AICI_AUTH_APP_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# GOOGLE OAUTH
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ---------------------------------------------------------------------------
# SWAGGER / API DOCS
# ---------------------------------------------------------------------------
AICI_SWAGGER_ENABLED=0
AICI_SWAGGER_USERNAME=admin
AICI_SWAGGER_PASSWORD=change_me
AICI_SWAGGER_DOCS_URL=/docs
AICI_SWAGGER_OPENAPI_URL=/openapi.json

# ---------------------------------------------------------------------------
# ADMIN PANEL
# ---------------------------------------------------------------------------
AICI_ADMIN_ENABLED=0
AICI_ADMIN_USERNAME=admin
AICI_ADMIN_PASSWORD=change_me

# ---------------------------------------------------------------------------
# STATIC ASSETS & CDN
# ---------------------------------------------------------------------------
AICI_STATIC_CDN_BASE_URL=https://cdn.your-domain.com
AICI_ASSET_MANIFEST_PATH=static/manifest.json

# ---------------------------------------------------------------------------
# STRIPE BILLING
# ---------------------------------------------------------------------------
AICI_STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
AICI_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
AICI_STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
AICI_STRIPE_PRICE_PRO=price_your_pro_plan_price_id_here
AICI_STRIPE_PRICE_ULTRA=price_your_ultra_plan_price_id_here
AICI_STRIPE_PRICE_FREE=price_your_free_plan_price_id_here
AICI_BILLING_TRIAL_DAYS=14
AICI_BILLING_ENTERPRISE_TERMS_DAYS=30

# ---------------------------------------------------------------------------
# CRYPTO PAYMENTS (NOWPayments)
# ---------------------------------------------------------------------------
AICI_CRYPTO_API_KEY=your_nowpayments_api_key_here
AICI_CRYPTO_API_SECRET=your_nowpayments_api_secret_here
AICI_CRYPTO_WEBHOOK_SECRET=your_nowpayments_webhook_secret_here
AICI_CRYPTO_USD_RATE=1.0
AICI_CRYPTO_FEE_PERCENT=0.5
AICI_CRYPTO_PAYOUT_ADDRESS=your_crypto_wallet_address_here
AICI_CRYPTO_PENDING_ALERT_MINUTES=30
AICI_CRYPTO_PROCESSING_ALERT_MINUTES=90

# ---------------------------------------------------------------------------
# EMAIL / SMTP
# ---------------------------------------------------------------------------
AICI_EMAIL_ENABLED=1
AICI_SMTP_HOST=smtp.your-email-provider.com
AICI_SMTP_PORT=587
AICI_SMTP_USERNAME=your_smtp_username_here
AICI_SMTP_PASSWORD=your_smtp_password_here
AICI_SMTP_USE_TLS=1
AICI_SMTP_USE_SSL=0
AICI_EMAIL_SENDER=noreply@your-domain.com
AICI_EMAIL_RECIPIENTS=admin@your-domain.com
AICI_SMTP_MAX_ATTEMPTS=2
AICI_SMTP_RETRY_DELAY_SECONDS=1.0

# ---------------------------------------------------------------------------
# API KEY MANAGEMENT
# ---------------------------------------------------------------------------
AICI_API_KEY=your_internal_api_key_here
AICI_API_KEY_SECRET=change_me_use_a_long_random_string
AICI_API_KEY_ROTATION_WEBHOOKS=
AICI_API_KEY_USAGE_WEBHOOKS=

# ---------------------------------------------------------------------------
# POSTGRES DATABASE
# ---------------------------------------------------------------------------
POSTGRES_DB=aici_auth
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# DEPLOYMENT & DOCKER / WATCHTOWER
# ---------------------------------------------------------------------------
AICI_WEBAPI_IMAGE=your-registry/aici-webapi:latest
AICI_WEBAPI_PORT=8000
WATCHTOWER_LABEL_ENABLE=true
WATCHTOWER_POLL_INTERVAL=300
WATCHTOWER_REPO_USER=your_docker_registry_user_here
WATCHTOWER_REPO_PASS=your_docker_registry_password_here

# ---------------------------------------------------------------------------
# TESTING & SMOKE TESTS
# ---------------------------------------------------------------------------
AICI_SMOKE_BASE_URL=http://localhost:8000
AICI_SMOKE_TIMEOUT=60
AICI_SMOKE_POLL_INTERVAL=2
AICI_ALLOW_REAL_EMAIL_IN_TESTS=0

# ---------------------------------------------------------------------------
# LEGACY / MISC
# ---------------------------------------------------------------------------
AI_CI_PRICES_CSV=data/merged_prices.csv
